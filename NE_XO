local function getTool(char)
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then return v end
    end
    return nil
end

local function createToolESP(plr, head)
    local gui = Instance.new("BillboardGui")
    gui.Name = "ToolESP"
    gui.Size = UDim2.new(0, 120, 0, 18)
    gui.StudsOffset = Vector3.new(0, -5, 0)
    gui.AlwaysOnTop = true
    gui.MaxDistance = math.huge
    gui.Parent = head
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
    txt.TextStrokeTransparency = 0
    txt.TextSize = 11
    txt.Font = Enum.Font.GothamBold
    txt.Text = ""
    txt.Parent = gui
    espCache[plr] = {gui = gui, label = txt}
end

RunService.RenderStepped:Connect(function()
    if not toolEnabled then return end
    for _, plr in Players:GetPlayers() do
        if plr ~= Player then
            local char = plr.Character
            local head = char and char:FindFirstChild("Head")
            if head then
                if not espCache[plr] then createToolESP(plr, head) end
                local data = espCache[plr]
                if data and data.label then
                    local tool = getTool(char)
                    data.label.Text = tool and "Weapon: " .. tool.Name or ""
                end
            end
        end
    end
end)


local spamEnabled = false
local SPAM_DELAY = 0.0001
local DIRECTION = Vector3.new(0.4623960256576538, 0, -0.8866735696792603)
local REMOTE_ARG = {DIRECTION, 1, false}
local remotes = {}
local spamThread

local function findRemotes()
    if not Player.Character then return end
    local char = Player.Character
    local names = {"Kitsune-Kitsune", "T-Rex-T-Rex", "Pain-Pain", "Dragon-Dragon", "Yeti-Yeti", "Control-Control"}
    remotes = {}
    for _, name in ipairs(names) do
        local model = char:FindFirstChild(name)
        if model then
            local remote = model:FindFirstChild("LeftClickRemote")
            if remote and remote:IsA("RemoteEvent") then
                table.insert(remotes, remote)
            end
        end
    end
end

local function startSpam()
    if spamThread then return end
    spamThread = task.spawn(function()
        while spamEnabled do
            if Player.Character then
                for _, remote in ipairs(remotes) do
                    if not spamEnabled then break end
                    pcall(function()
                        remote:FireServer(unpack(REMOTE_ARG))
                    end)
                    task.wait(SPAM_DELAY)
                end
            end
            task.wait()
        end
        spamThread = nil
    end)
end


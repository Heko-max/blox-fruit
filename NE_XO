    local last = tick()
    local frames = 0
    RunService.RenderStepped:Connect(function()
        frames = frames + 1
        if tick() - last >= 1 then
            fpsText.Text = "FPS : " .. frames
            if frames < 30 then
                fpsText.TextColor3 = Color3.fromRGB(255, 0, 0)
                fpsDot.TextColor3 = Color3.fromRGB(255, 0, 0)
            else
                fpsText.TextColor3 = Color3.fromRGB(0, 255, 0)
                fpsDot.TextColor3 = Color3.fromRGB(0, 255, 0)
            end
            frames = 0
            last = tick()
        end
        local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        pingText.Text = "Ping : " .. ping
        if ping <= 100 then
            pingText.TextColor3 = Color3.fromRGB(0, 255, 0)
            pingDot.TextColor3 = Color3.fromRGB(0, 255, 0)
        else
            pingText.TextColor3 = Color3.fromRGB(255, 0, 0)
            pingDot.TextColor3 = Color3.fromRGB(255, 0, 0)
        end
    end)

    local function makeDraggable(frame)
        local dragging = false
        local dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragStart = input.Position
                startPos = frame.Position
            end
        end)
        frame.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    makeDraggable(fpsFrame)
    makeDraggable(pingFrame)
end)


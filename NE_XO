local SKY_HOVERING = false
local skyHoverLoop
local skyReturnCFrame

local function stopSkyHover()
    SKY_HOVERING = false
    if skyHoverLoop then task.cancel(skyHoverLoop) end
    local char = Player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            if skyReturnCFrame then hrp.CFrame = skyReturnCFrame end
        end
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = false end
    end
    skyReturnCFrame = nil
end

local function startSkyHover()
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    SKY_HOVERING = true
    skyReturnCFrame = hrp.CFrame
    skyHoverLoop = task.spawn(function()
        while SKY_HOVERING do
            local c = Player.Character
            if not c then stopSkyHover() break end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then stopSkyHover() break end
            h.AssemblyLinearVelocity = Vector3.zero
            h.AssemblyAngularVelocity = Vector3.zero
            h.CFrame = CFrame.new(h.Position.X, math.random(2000, 999999), h.Position.Z)
            task.wait(0.01)
        end
    end)
end


speedEnabled = false
speedValue = 100
humanoid = nil

function applySpeed()
    if humanoid and speedEnabled then
        humanoid.WalkSpeed = speedValue
    end
end

function onCharSpeed(c)
    humanoid = c:WaitForChild("Humanoid")
    applySpeed()
    humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if speedEnabled and humanoid.WalkSpeed ~= speedValue then
            humanoid.WalkSpeed = speedValue
        end
    end)
end

Player.CharacterAdded:Connect(onCharSpeed)
if Player.Character then onCharSpeed(Player.Character) end


function safeTeleport(pos)
    char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        root = char.HumanoidRootPart
        root.Anchored = true
        root.CFrame = CFrame.new(pos)

        task.delay(1, function()
            if root then
                root.Anchored = false
            end
        end)
    end
end


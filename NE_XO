local espEnabled = false
local espConnections = {}

local function createOrUpdateESP(plr)
    if plr == Player then return end
    local function onCharAdded(char)
        if not espEnabled then return end
        local head = char:WaitForChild("Head", 5)
        local humanoid = char:WaitForChild("Humanoid", 5)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if not (head and humanoid and root) then return end
        local old = head:FindFirstChild("ESP")
        if old then old:Destroy() end
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ESP"
        billboard.Adornee = head
        billboard.Parent = head
        billboard.Size = UDim2.new(0, 220, 0, 36)
        billboard.StudsOffset = Vector3.new(0, 3.2, 0)
        billboard.AlwaysOnTop = true
        billboard.MaxDistance = math.huge
        local text = Instance.new("TextLabel")
        text.Size = UDim2.new(1, 0, 1, 0)
        text.BackgroundTransparency = 1
        text.TextColor3 = Color3.new(1, 1, 1)
        text.TextStrokeTransparency = 0.4
        text.TextStrokeColor3 = Color3.new(0, 0, 0)
        text.Font = Enum.Font.SourceSansBold
        text.TextSize = 14
        text.Parent = billboard
        local conn = RunService.RenderStepped:Connect(function()
            if not espEnabled or not char.Parent or not head.Parent then
                pcall(function() conn:Disconnect() end)
                return
            end
            local myChar = Player.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end
            local distance = (myRoot.Position - root.Position).Magnitude
            local health = math.floor(humanoid.Health)
            local maxHealth = math.floor(humanoid.MaxHealth)
            text.Text = string.format("%s | %d/%d HP | %.0fm", plr.Name, health, maxHealth, distance)
        end)
        table.insert(espConnections, conn)
    end
    if plr.Character then task.spawn(onCharAdded, plr.Character) end
    plr.CharacterAdded:Connect(onCharAdded)
end

espToggleFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        espEnabled = not espEnabled
        TweenService:Create(espToggle, TweenInfo.new(0.25), {BackgroundColor3 = espEnabled and Colors.ToggleOn or Colors.ToggleOff}):Play()
        TweenService:Create(espKnob, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Position = espEnabled and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10)}):Play()
        if espEnabled then
            for _, p in Players:GetPlayers() do createOrUpdateESP(p) end
            local conn = Players.PlayerAdded:Connect(function(p)
                if espEnabled then createOrUpdateESP(p) end
            end)
            table.insert(espConnections, conn)
        else
            for _, c in espConnections do pcall(function() c:Disconnect() end) end
            espConnections = {}
            for _, p in Players:GetPlayers() do
                if p.Character then
                    local h = p.Character:FindFirstChild("Head")
                    if h then
                        local e = h:FindFirstChild("ESP")
                        if e then e:Destroy() end
                    end
                end
            end
        end
    end
end)


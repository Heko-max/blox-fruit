local fastAttack = false
local FA_RANGE = 180
local FA_MAX = 6
local FA_DELAY = 0

local RS = game:GetService("ReplicatedStorage")
local CS = game:GetService("CollectionService")
local charFA, hrpFA

local function updateCharFA()
    charFA = Player.Character or Player.CharacterAdded:Wait()
    hrpFA = charFA:WaitForChild("HumanoidRootPart")
end

updateCharFA()
Player.CharacterAdded:Connect(updateCharFA)

local registerAttack = RS.Modules.Net["RE/RegisterAttack"]
local registerHit = debug.getupvalue(getrenv()._G.SendHitsToServer, 1)

local function getMobsFA()
    if not hrpFA then return {} end
    local mobs = {}
    local pos = hrpFA.Position
    for _, mob in ipairs(CS:GetTagged("BasicMob")) do
        local hum = mob:FindFirstChildOfClass("Humanoid")
        local root = mob:FindFirstChild("HumanoidRootPart")
        if hum and root and hum.Health > 0 and (root.Position - pos).Magnitude <= FA_RANGE then
            table.insert(mobs, {mob, root})
            if #mobs >= FA_MAX then break end
        end
    end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 and (root.Position - pos).Magnitude <= FA_RANGE then
                table.insert(mobs, {plr.Character, root})
                if #mobs >= FA_MAX then break end
            end
        end
    end
    return mobs
end

local function doFastAttack()
    local mobs = getMobsFA()
    if #mobs == 0 then return end
    registerAttack:FireServer(0/0)
    coroutine.resume(registerHit, mobs[1][2], {table.unpack(mobs, 2)})
end

task.spawn(function()
    while task.wait(FA_DELAY) do
        if fastAttack then
            pcall(doFastAttack)
        end
    end
end)


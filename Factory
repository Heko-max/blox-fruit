--  TIMER SCANNER
-- ════════════════════════════════════════════════════════════
local function parseTime(text)
    local m, s = text:match("%[?(%d+):(%d+)%]?")
    if m and s then
        return tonumber(m) * 60 + tonumber(s)
    end
    return nil
end

local function findTimerLabel()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local secs = parseTime(obj.Text)
            if secs then
                local ancestor = obj
                local worldPos = nil

                while ancestor do
                    if ancestor:IsA("BasePart") then
                        worldPos = ancestor.Position
                        break
                    elseif ancestor:IsA("BillboardGui") or ancestor:IsA("SurfaceGui") then
                        local adornee = ancestor.Adornee
                        if adornee and adornee:IsA("BasePart") then
                            worldPos = adornee.Position
                            break
                        end
                    end
                    ancestor = ancestor.Parent
                end

                if worldPos then
                    local dist = (worldPos - TIMER_WORLD_POS).Magnitude
                    if dist <= TIMER_SEARCH_RADIUS then
                        return obj
                    end
                end
            end
        end
    end
    return nil
end



-- ════════════════════════════════════════════════════════════
--  MAIN LOOP  –  scan → mirror → teleport
-- ════════════════════════════════════════════════════════════
local totalSecs   = nil
local lastSecs    = nil
local timerSource = nil

task.spawn(function()

    -- ── phase 1: find the timer ───────────────────────────────
    local attempts = 0
    while not timerSource do
        timerSource = findTimerLabel()
        attempts += 1
        if attempts % 20 == 0 then
            local dots = string.rep(".", (attempts / 20) % 4)
            scanLabel.Text = "SCANNING" .. dots
        end
        task.wait(POLL_RATE)
    end

    scanLabel.Text       = "CORE TIMER FOUND  ✓"
    scanLabel.TextColor3 = GREEN
    dot.BackgroundColor3 = GREEN

    -- ── phase 2: mirror the timer ─────────────────────────────
    while gui and gui.Parent do

        if not timerSource or not timerSource.Parent then
            timerSource = findTimerLabel()
            task.wait(POLL_RATE)
            continue
        end

        local secs = parseTime(timerSource.Text)

        if secs then
            if not totalSecs or secs > totalSecs then
                totalSecs = secs
            end

            local mm        = math.floor(secs / 60)
            local ss        = secs % 60
            timerLabel.Text = string.format("[%d:%02d]", mm, ss)

            if secs ~= lastSecs then
                lastSecs  = secs
                local pct = totalSecs and (secs / totalSecs) or 1

                TweenService:Create(barFill,
                    TweenInfo.new(0.9, Enum.EasingStyle.Linear),
                    { Size = UDim2.new(pct, 0, 1, 0) }
                ):Play()

                if secs <= 30 then
                    TweenService:Create(timerLabel, TweenInfo.new(0.3),
                        { TextColor3 = Color3.fromRGB(255, 80, 40) }):Play()
                    TweenService:Create(stroke, TweenInfo.new(0.3),
                        { Color = Color3.fromRGB(255, 80, 40) }):Play()
                end
            end

            -- ── time's up → teleport ──────────────────────────
            if secs <= 0 then
                timerLabel.Text      = "[0:00]"
                scanLabel.Text       = "TELEPORTING..."
                scanLabel.TextColor3 = ACCENT

                task.wait(0.4)

                local char = player.Character or player.CharacterAdded:Wait()
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = CFrame.new(TARGET_POS)
                end

                task.wait(0.5)
                TweenService:Create(card,
                    TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.In),
                    { Position = UDim2.new(0.5, 0, 1, 80) }
                ):Play()
                task.wait(0.5)
                gui:Destroy()
                return
            end
        else
            timerLabel.Text = "--:--"
        end

        task.wait(POLL_RATE)
    end
end)

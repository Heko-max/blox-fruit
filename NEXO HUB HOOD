-- 10. Mini Toggle Logic
local isHubVisible = true
local lastMainFramePosition = MainFrame.Position

ToggleBtn.MouseButton1Click:Connect(function()
    isHubVisible = not isHubVisible
    local currentToggleCenterPos = UDim2.new(
        ToggleBtn.Position.X.Scale,
        ToggleBtn.Position.X.Offset + (ToggleBtn.Size.X.Offset / 2),
        ToggleBtn.Position.Y.Scale,
        ToggleBtn.Position.Y.Offset + (ToggleBtn.Size.Y.Offset / 2)
    )
    local targetMainScale = isHubVisible and UDim2.new(0, 360, 0, 520) or UDim2.new(0, 0, 0, 0)
    local targetMainPos = isHubVisible and lastMainFramePosition or currentToggleCenterPos
    local targetGlowScale = isHubVisible and UDim2.new(0, 420, 0, 580) or UDim2.new(0, 0, 0, 0)
    local targetGlowPos = isHubVisible and UDim2.new(lastMainFramePosition.X.Scale, lastMainFramePosition.X.Offset - 30, lastMainFramePosition.Y.Scale, lastMainFramePosition.Y.Offset - 30) or currentToggleCenterPos
    
    if isHubVisible then
        MainFrame.Visible = true
        GlowContainer.Visible = true
    else
        lastMainFramePosition = MainFrame.Position
    end
    
    local mainTween = TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = targetMainScale, Position = targetMainPos})
    local glowTween = TweenService:Create(GlowContainer, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = targetGlowScale, Position = targetGlowPos})
    
    mainTween:Play()
    glowTween:Play()
    
    mainTween.Completed:Connect(function()
        if not isHubVisible then
            MainFrame.Visible = false
            GlowContainer.Visible = false
        end
    end)
    
    if MINI_UI_IMAGE_ID == "" then
        ToggleTextFallback.Text = isHubVisible and "⚡" or "O"
    end
end)

-- 11. Core Engine Loop
local frameTimeTable = {}
local nextDiagnosticsUpdate = os.clock() + 0.5

RunService.RenderStepped:Connect(function(deltaTime)
    local currentRotation = (tick() * 75) % 360
    for _, gradient in ipairs(dynamicGradients) do
        if gradient and gradient.Parent then
            gradient.Rotation = currentRotation
        end
    end
    
    local currentTime = os.clock()
    table.insert(frameTimeTable, currentTime)
    while frameTimeTable[1] and frameTimeTable[1] < currentTime - 1 do
        table.remove(frameTimeTable, 1)
    end
    
    if currentTime >= nextDiagnosticsUpdate then
        local trueFPS = #frameTimeTable
        FpsLabel.Text = "FPS: " .. tostring(trueFPS)
        
        local rawPing = 0
        pcall(function()
            rawPing = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        end)
        
        if rawPing <= 0 then rawPing = 1 end
        PingLabel.Text = "Ping: " .. tostring(rawPing) .. " ms"
        
        nextDiagnosticsUpdate = currentTime + 0.5
    end
end)

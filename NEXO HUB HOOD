local NotificationActive = false
local function showNotification(message)
    if NotificationActive then return end
    NotificationActive = true
    local NotifFrame = Instance.new("Frame")
    NotifFrame.Name = "NexoNotification"
    NotifFrame.Size = UDim2.new(0, 240, 0, 42)
    NotifFrame.Position = UDim2.new(1, 30, 0, 30)
    NotifFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    NotifFrame.BorderSizePixel = 0
    NotifFrame.ZIndex = 100
    NotifFrame.Parent = ScreenGui
    local NotifCorner = Instance.new("UICorner")
    NotifCorner.CornerRadius = UDim.new(0, 8)
    NotifCorner.Parent = NotifFrame
    local NotifLaserStroke = Instance.new("UIStroke")
    NotifLaserStroke.Thickness = 1.5
    NotifLaserStroke.Color = Color3.fromRGB(255, 255, 255)
    NotifLaserStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    NotifLaserStroke.Parent = NotifFrame
    local NotifGradient = Instance.new("UIGradient")
    applyLongWhiteLaser(NotifGradient)
    NotifGradient.Parent = NotifLaserStroke
    table.insert(dynamicGradients, NotifGradient)
    local NotifText = Instance.new("TextLabel")
    NotifText.Size = UDim2.new(1, 0, 1, 0)
    NotifText.BackgroundTransparency = 1
    NotifText.Text = message
    NotifText.TextColor3 = Color3.fromRGB(255, 255, 255)
    NotifText.Font = Enum.Font.GothamMedium
    NotifText.TextSize = 13
    NotifText.ZIndex = 101
    NotifText.Parent = NotifFrame
    local tweenIn = TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -260, 0, 30)
    })
    tweenIn:Play()
    task.delay(2.5, function()
        local tweenOut = TweenService:Create(NotifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 30, 0, 30)
        })
        tweenOut:Play()
        tweenOut.Completed:Connect(function()
            for i, grad in ipairs(dynamicGradients) do
                if grad == NotifGradient then
                    table.remove(dynamicGradients, i)
                    break
                end
            end
            NotifFrame:Destroy()
            NotificationActive = false
        end)
    end)
end

local function copyLinkToClipboard(url, name)
    local success, _ = pcall(function()
        if setclipboard then setclipboard(url) elseif to_clipboard then to_clipboard(url) end
    end)
    showNotification("🔗 " .. name .. " Link Copied!")
end


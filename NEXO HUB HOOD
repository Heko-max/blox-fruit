local BoxingComm = ReplicatedStorage:WaitForChild("BoxingComm")

local function fireKick()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character then
            local args = {
                [1] = "RegisterHit",
                [2] = "Kick",
                [3] = plr.Character
            }
            BoxingComm:FireServer(unpack(args))
        end
    end
end

local function fireAutoJoin()
    local args = { [1] = "JoinQueue" }
    BoxingComm:FireServer(unpack(args))
end

